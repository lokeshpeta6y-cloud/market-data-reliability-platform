# ============================================================
# Market Data Reliability Platform — Environment Variables
# ============================================================
#
# Copy this file to .env and fill in the values for your
# environment. Variables marked [REQUIRED] must be set before
# running the platform. Variables marked [OPTIONAL] have safe
# defaults suitable for local development.
#
# DO NOT commit .env to version control.
# ============================================================


# ============================================================
# KAFKA / REDPANDA
# ============================================================

# [REQUIRED] Comma-separated list of Kafka bootstrap servers.
# In Docker Compose, use the internal service name.
# For local-only (non-Docker) use, set to localhost:9092.
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# [OPTIONAL] Kafka consumer group ID prefix. Individual
# services append their own suffix (e.g. mdrp-validation).
KAFKA_CONSUMER_GROUP_PREFIX=mdrp

# [OPTIONAL] Kafka producer acks setting. 'all' for maximum
# durability; '1' for higher throughput in dev.
KAFKA_PRODUCER_ACKS=all

# [OPTIONAL] Kafka producer linger time in milliseconds.
# Batching events for up to this duration before sending.
KAFKA_PRODUCER_LINGER_MS=5

# [OPTIONAL] Kafka consumer max poll interval in milliseconds.
KAFKA_CONSUMER_MAX_POLL_INTERVAL_MS=300000

# [OPTIONAL] Number of messages to batch before committing offsets.
KAFKA_CONSUMER_COMMIT_BATCH_SIZE=100

# [OPTIONAL] Schema Registry URL. Used by services that
# validate Avro/Protobuf schemas before producing.
KAFKA_SCHEMA_REGISTRY_URL=http://redpanda:8081


# ============================================================
# REDIS
# ============================================================

# [REQUIRED] Redis connection URL. Supports redis:// and
# rediss:// (TLS). Database index appended as /N.
REDIS_URL=redis://redis:6379/0

# [OPTIONAL] Redis connection pool size per service.
REDIS_MAX_CONNECTIONS=20

# [OPTIONAL] TTL in seconds for hot-cache instrument data.
# Stale data alert fires at 600s (10 min).
REDIS_INSTRUMENT_TTL_SECONDS=300

# [OPTIONAL] TTL in seconds for provider quality score cache.
REDIS_QUALITY_SCORE_TTL_SECONDS=60


# ============================================================
# S3 / MinIO (Bronze Storage Layer)
# ============================================================

# [REQUIRED] S3-compatible endpoint URL.
# For MinIO in Docker: http://minio:9000
# For AWS S3: leave blank (SDK uses default endpoint)
S3_ENDPOINT_URL=http://minio:9000

# [REQUIRED] S3 / MinIO access key ID.
AWS_ACCESS_KEY_ID=mdrp

# [REQUIRED] S3 / MinIO secret access key.
AWS_SECRET_ACCESS_KEY=mdrp_secret_local

# [OPTIONAL] AWS region. Required for real S3; ignored by MinIO.
AWS_DEFAULT_REGION=us-east-1

# [OPTIONAL] S3 bucket name for Bronze (raw) event storage.
S3_BRONZE_BUCKET=mdrp-bronze

# [OPTIONAL] S3 bucket name for replay snapshots.
S3_REPLAY_BUCKET=mdrp-replay

# [OPTIONAL] S3 path prefix for bronze event partitions.
# Data is written as: {prefix}/provider={provider}/date={YYYY-MM-DD}/
S3_BRONZE_PREFIX=events

# [OPTIONAL] Maximum number of events to buffer before
# flushing a Parquet batch to Bronze storage.
BRONZE_FLUSH_BATCH_SIZE=1000

# [OPTIONAL] Maximum seconds to wait before flushing a partial
# batch (even if BRONZE_FLUSH_BATCH_SIZE not reached).
BRONZE_FLUSH_INTERVAL_SECONDS=30


# ============================================================
# SNOWFLAKE (Silver / Gold Layer — production only)
# ============================================================
# Leave SNOWFLAKE_ACCOUNT blank to run without Snowflake
# (the rest of the pipeline — Redis, MinIO, Kafka — works fine).
# Run infra/snowflake/001–006 DDL scripts once before enabling.
# ============================================================

# [OPTIONAL] Snowflake account identifier.
# Format: <orgname>-<account_locator>  (e.g. YMAUZRZ-ME29964)
# or the legacy <locator>.<region>     (e.g. xy12345.us-east-1)
SNOWFLAKE_ACCOUNT=

# [OPTIONAL] Snowflake login name for the service account.
SNOWFLAKE_USER=

# [OPTIONAL] Snowflake Programmatic Access Token (PAT).
# Preferred auth method — bypasses MFA and does not expire per-session.
# Generate in: Snowflake UI → Profile → Programmatic Access Tokens.
# Takes precedence over SNOWFLAKE_PASSWORD when both are set.
SNOWFLAKE_PAT_TOKEN=

# [OPTIONAL] Snowflake password (fallback if PAT is not used).
# Avoid in production; prefer PAT or RSA key-pair auth instead.
SNOWFLAKE_PASSWORD=

# [OPTIONAL] Compute warehouse for COPY INTO and MERGE loads.
# Created by 001_database_and_warehouses.sql.
SNOWFLAKE_WAREHOUSE=INGESTION_WH

# [OPTIONAL] Target Snowflake database.
# Must match the database created by 001_database_and_warehouses.sql.
SNOWFLAKE_DATABASE=MARKET_DATA

# [OPTIONAL] Schema for validated CurveEvent rows (Silver layer).
# Created by 002_schemas.sql.
SNOWFLAKE_SCHEMA_SILVER=SILVER_EVENTS

# [OPTIONAL] Schema for reconciled ForwardCurveSnapshot rows (Gold layer).
# Created by 002_schemas.sql.
SNOWFLAKE_SCHEMA_GOLD=GOLD_CURVES

# [OPTIONAL] Snowflake internal stage name used for PUT / COPY INTO.
# Created by 005_stages_and_pipes.sql.
SNOWFLAKE_STAGE_NAME=MDRP_STAGE


# ============================================================
# DATABENTO (Live market data provider)
# ============================================================

# [OPTIONAL] Databento API key. Required when using the live
# Databento provider; leave blank for emulator-only mode.
DATABENTO_API_KEY=

# [OPTIONAL] Databento dataset to subscribe to
# (e.g. GLBX.MDP3 for CME Globex).
DATABENTO_DATASET=GLBX.MDP3

# [OPTIONAL] Comma-separated list of symbols to subscribe to.
# Use 'ALL_SYMBOLS' for full feed (requires appropriate licence).
DATABENTO_SYMBOLS=ESM4,CLM4,GCM4

# [OPTIONAL] Databento schema (e.g. mbp-1, trades, ohlcv-1m).
DATABENTO_SCHEMA=mbp-1

# [OPTIONAL] Databento feed mode: live or historical-streaming.
DATABENTO_MODE=historical-streaming


# ============================================================
# ALERTING / NOTIFICATIONS
# ============================================================

# [OPTIONAL] Microsoft Teams incoming webhook URL.
# When set, ops-api routes critical alerts to this channel.
TEAMS_WEBHOOK_URL=

# [OPTIONAL] SMTP server for email alerts.
SMTP_HOST=

# [OPTIONAL] SMTP port (25, 465, or 587).
SMTP_PORT=587

# [OPTIONAL] SMTP username.
SMTP_USERNAME=

# [OPTIONAL] SMTP password.
SMTP_PASSWORD=

# [OPTIONAL] Alert sender email address.
ALERT_FROM_EMAIL=mdrp-alerts@example.com

# [OPTIONAL] Comma-separated list of email recipients for
# critical alerts.
ALERT_TO_EMAILS=

# [OPTIONAL] Pagerduty integration key for critical escalation.
PAGERDUTY_INTEGRATION_KEY=


# ============================================================
# OBSERVABILITY (OpenTelemetry / Prometheus)
# ============================================================

# [OPTIONAL] OTLP exporter endpoint (gRPC).
# Jaeger all-in-one in Docker: http://jaeger:4317
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# [OPTIONAL] OTLP transport protocol: grpc or http/protobuf.
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# [OPTIONAL] Sampling ratio for traces (0.0–1.0).
# Use 1.0 in development; 0.1 in production.
OTEL_TRACES_SAMPLER_ARG=1.0

# [OPTIONAL] Metrics export interval in milliseconds.
OTEL_METRIC_EXPORT_INTERVAL=15000

# [OPTIONAL] Log level for all platform services.
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# [OPTIONAL] Log format: json (structured, for production) or
# text (human-readable, for development).
LOG_FORMAT=json


# ============================================================
# SERVICE HTTP / METRICS PORTS
# These are consumed by each service at startup. Override only
# if you have port conflicts on the host machine.
# ============================================================

# [OPTIONAL] ops-api HTTP port.
HTTP_PORT=8000

# [OPTIONAL] Prometheus metrics ports per service.
# Should match the ports declared in docker-compose.yml.
METRICS_PORT_PROVIDER_EMULATOR=8001
METRICS_PORT_VALIDATION=8002
METRICS_PORT_BRONZE_WRITER=8003
METRICS_PORT_NORMALIZATION=8004
METRICS_PORT_REDIS_WRITER=8005
METRICS_PORT_REPLAY_ENGINE=8006
METRICS_PORT_OPS_API=8007
METRICS_PORT_SILVER_LOADER=8008
METRICS_PORT_GOLD_LOADER=8009


# ============================================================
# PROVIDER EMULATOR (development / testing only)
# ============================================================
# The emulator generates synthetic energy forward curves for all
# six instruments and publishes them to market.events.raw.
# No external API is required — data flows automatically on startup.
# ============================================================

# [OPTIONAL] Comma-separated instruments to simulate.
INSTRUMENTS=TTF,NBP,TTF_POWER,BRENT,WTI,EU_ETS

# [OPTIONAL] Label stamped on every emitted event.
PROVIDER_NAME=provider-emulator

# [OPTIONAL] Seconds between full curve batches (all instruments).
PUBLISH_INTERVAL_SECONDS=5.0

# [OPTIONAL] Fault injection rates — each is independently configurable.
# Set to 0.0 to disable a fault type; 1.0 to force it on every event.
FAULT_RATE_DUPLICATE=0.02        # 2%  — publishes the same event_id twice
FAULT_RATE_MALFORMED=0.01        # 1%  — corrupts a required field
FAULT_RATE_DELAYED=0.05          # 5%  — holds the event 2–30 s before release
FAULT_RATE_OUT_OF_ORDER=0.03     # 3%  — shuffles event relative to neighbours
FAULT_RATE_SCHEMA_DRIFT=0.005    # 0.5% — renames payload fields (e.g. price→px)
FAULT_RATE_STALE=0.01            # 1%  — backdates event_timestamp by 2–24 h
FAULT_RATE_PARTIAL_CURVE=0.02    # 2%  — drops 20–50% of tenors from a batch

# [OPTIONAL] Delay queue bounds (seconds held for DELAYED / OUT_OF_ORDER faults).
DELAY_MIN_SECONDS=2.0
DELAY_MAX_SECONDS=30.0
DELAY_QUEUE_MAX_SIZE=500

# [OPTIONAL] Number of historical Databento days to pull on adapter init.
DATABENTO_LOOKBACK_DAYS=5


# ============================================================
# REPLAY ENGINE
# ============================================================

# [OPTIONAL] Maximum number of concurrent replay jobs.
REPLAY_MAX_CONCURRENT_JOBS=3

# [OPTIONAL] Maximum replay speed multiplier (e.g. 10 = 10× real-time).
REPLAY_MAX_SPEED_MULTIPLIER=100

# [OPTIONAL] Chunk size (number of events) read per S3 GET during replay.
REPLAY_CHUNK_SIZE=5000
